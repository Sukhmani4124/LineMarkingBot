      <uri>model://road</uri>
      <pose> 9.9 -21.5 0  0 0 0</pose>
    </include>

    <!-- ================================================================== -->
    <!--                      TRAFFIC SIGNS                                 -->
    <!-- ================================================================== -->

    <!-- Stop Signs -->
    <include>
      <name>stop_sign_0</name>
      <uri>model://stop_sign</uri>
      <pose>-0.5  10.5 0  0 0 0</pose>
    </include>
    <include>
