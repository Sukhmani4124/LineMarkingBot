    <!-- ── Vertical roads (X ≈ +6.8) ────────────────────────────────────── -->
    <include>
      <name>road_v4</name>
      <uri>model://road</uri>
      <pose>6.8 -7    0  0 0 1.5708</pose>
    </include>
    <include>
      <name>road_v5</name>
      <uri>model://road</uri>
      <pose>6.8 -0.8  0  0 0 1.5708</pose>
    </include>
    <include>
      <name>road_v6</name>
      <uri>model://road</uri>
      <pose>6.8  5.4  0  0 0 1.5708</pose>
    </include>
    <include>
      <name>road_v7</name>
      <uri>model://road</uri>
