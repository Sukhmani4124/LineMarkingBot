    <!-- ── Vertical roads (X ≈ −8.65) ───────────────────────────────────── -->
    <include>
      <name>road_v11</name>
      <uri>model://road</uri>
      <pose>-8.65 -7    0  0 0 1.5708</pose>
    </include>
    <include>
      <name>road_v12</name>
      <uri>model://road</uri>
      <pose>-8.65 -0.8  0  0 0 1.5708</pose>
    </include>
    <include>
      <name>road_v13</name>
      <uri>model://road</uri>
      <pose>-8.65  5.4  0  0 0 1.5708</pose>
    </include>
    <include>
      <name>road_v14</name>
      <uri>model://road</uri>
      <pose>-8.65 -13.2 0  0 0 1.5708</pose>
    </include>

    <!-- ── Road Section (intersection / roundabout area) ────────────────── -->
    <include>
      <name>roadsection_1</name>
      <uri>model://roadsection</uri>
      <pose>-0.8 -7 -0.001 0 0 0</pose>
    </include>

    <!-- ── Parking-area roads ────────────────────────────────────────────── -->
    <include>
      <name>road_park0</name>
      <uri>model://road</uri>
      <pose>14.2 -19.4 0  0 0 1.5708</pose>
    </include>
    <include>
      <name>road_park1</name>
      <uri>model://road</uri>
      <pose> 6.8 -19.4 0  0 0 1.5708</pose>
    </include>
    <include>
